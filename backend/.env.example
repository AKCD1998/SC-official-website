PORT=3000
CORS_ORIGIN=http://localhost:5173,https://your-frontend-host.example
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/MAIN_WEBSITE_DB
JWT_SECRET=change-me
OTP_SECRET=change-me
OTP_TTL_MINUTES=10
SENDGRID_API_KEY=SG.your_sendgrid_key
MAIL_USER=verified_sender@example.com
MAIL_TO=receiver@example.com

# Rx1011 module
# Prefer these namespaced values in the shared service.
RX1011_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/RX1011_DB
RX1011_JWT_SECRET=change-me
RX1011_PATIENTS_CSV_PATH=
ADMIN_SQL_EXECUTOR_MAX_SQL_LENGTH=20000
ADMIN_SQL_EXECUTOR_TIMEOUT_MS=5000
ADMIN_SQL_EXECUTOR_ROW_CAP=200
ADMIN_TABLE_BROWSER_ROW_CAP=500
