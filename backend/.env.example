PORT=3000
CORS_ORIGIN=http://localhost:5173,https://your-frontend-host.example
SC_OFFICIAL_DATABASE_URL=<SC_OFFICIAL_WEBSITE_DATABASE_URL>
# Legacy fallback only. Prefer SC_OFFICIAL_DATABASE_URL in shared backend deployments.
DATABASE_URL=
JWT_SECRET=change-me
OTP_SECRET=change-me
OTP_TTL_MINUTES=10
SENDGRID_API_KEY=<SHARED_WEBSITE_SENDGRID_API_KEY>
MAIL_USER=verified_sender@example.com
MAIL_TO=receiver@example.com

# SCCRM
SCCRM_ACCESS_JWT_SECRET=change-me
SCCRM_REFRESH_TOKEN_SECRET=change-me
SCCRM_STAFF_PIN=123456
SCCRM_LINE_CHANNEL_ID=
SCCRM_LINE_CHANNEL_SECRET=
SCCRM_LINE_REDIRECT_URI=
SCCRM_GOOGLE_CLIENT_ID=
SCCRM_GOOGLE_CLIENT_SECRET=
SCCRM_GOOGLE_REDIRECT_URI=
SCCRM_ALLOWED_STAFF_DEVICE_NAMES=

# Homepage slider admin — comma-separated emails allowed to change slider images
SITE_ADMIN_EMAILS=your-admin@example.com

# Cloudflare R2 — shared storage for slider image uploads
# (Reused from the cancelled scGlamLiff OCR project. The old SCGLAMLIFF_R2_* vars remain
#  for backward compatibility — these generic R2_* vars are a clean parallel set.)
# Leave blank to use local disk fallback (development only; not persistent on Render free tier).
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<R2_ACCESS_KEY_ID>
R2_SECRET_ACCESS_KEY=<R2_SECRET_ACCESS_KEY>
R2_BUCKET=<bucket-name>
R2_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev

# ReactNJob module
# Use a separate SendGrid key so this module cannot share the website SendGrid key by accident.
REACTNJOB_SUBMIT_URL=https://script.google.com/macros/s/YOUR_SUBMIT_SCRIPT_ID/exec
REACTNJOB_QUICK_CV_SUBMIT_URL=https://script.google.com/macros/s/YOUR_QUICK_CV_SCRIPT_ID/exec
REACTNJOB_SENDGRID_API_KEY=<REACTNJOB_SENDGRID_API_KEY>
REACTNJOB_FROM_EMAIL=verified_reactnjob_sender@example.com
REACTNJOB_HR_EMAIL=hr@example.com
REACTNJOB_LINE_CHANNEL_SECRET=change-me
REACTNJOB_LINE_CHANNEL_ACCESS_TOKEN=change-me
REACTNJOB_LINE_NOTIFY_MODE=multicast
REACTNJOB_LINE_NOTIFY_USER_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REACTNJOB_LINE_NOTIFY_ADMIN_URL=

# Rx1011 module
# Prefer these namespaced values in the shared service.
RX1011_DATABASE_URL=<RX1011_DATABASE_URL>
RX1011_JWT_SECRET=change-me
RX1011_PATIENTS_CSV_PATH=
ADMIN_SQL_EXECUTOR_MAX_SQL_LENGTH=20000
ADMIN_SQL_EXECUTOR_TIMEOUT_MS=5000
ADMIN_SQL_EXECUTOR_ROW_CAP=200
ADMIN_TABLE_BROWSER_ROW_CAP=500

# DigitalPJK module
# These names are intentionally project-scoped so DigitalPJK cannot use the shared website DATABASE_URL/JWT_SECRET by accident.
DIGITALPJK_DATABASE_URL=<DIGITALPJK_DATABASE_URL>
DIGITALPJK_JWT_SECRET=change-me
DIGITALPJK_JWT_EXPIRES_IN=1h
DIGITALPJK_CEO_NAME_TH=
DIGITALPJK_LOGIN_RATE_LIMIT_WINDOW_MS=60000
DIGITALPJK_LOGIN_RATE_LIMIT_MAX=5
DIGITALPJK_PDF_WRITE_SAMPLE=false
DIGITALPJK_PDF_SAMPLE_DIR=

# scGlamLiff module
# These names are intentionally project-scoped so scGlamLiff cannot use the shared website DATABASE_URL/JWT_SECRET by accident.
SCGLAMLIFF_ADMIN_DISPLAY_NAME=
SCGLAMLIFF_ADMIN_PASSWORD=
SCGLAMLIFF_ADMIN_USERNAME=
SCGLAMLIFF_BASE_URL=
SCGLAMLIFF_COOKIE_SAMESITE=
SCGLAMLIFF_COOKIE_SECURE=
SCGLAMLIFF_DATABASE_URL=
SCGLAMLIFF_FRONTEND_ORIGINS=
SCGLAMLIFF_GAS_APPOINTMENTS_URL=
SCGLAMLIFF_GAS_SECRET=
SCGLAMLIFF_JWT_SECRET=
SCGLAMLIFF_LINE_CHANNEL_ID=
SCGLAMLIFF_LINE_CHANNEL_SECRET=
SCGLAMLIFF_NODE_ENV=
SCGLAMLIFF_OMISE_SECRET_KEY=
SCGLAMLIFF_PORT=
SCGLAMLIFF_R2_ACCESS_KEY_ID=
SCGLAMLIFF_R2_BUCKET=
SCGLAMLIFF_R2_ENDPOINT=
SCGLAMLIFF_R2_KEY_PREFIX=
SCGLAMLIFF_R2_SECRET_ACCESS_KEY=
SCGLAMLIFF_RECEIPT_UPLOAD_STORAGE_DIR=
SCGLAMLIFF_SEED_DISPLAY_NAME=
SCGLAMLIFF_SEED_PASSWORD=
SCGLAMLIFF_SEED_ROLE=
SCGLAMLIFF_SEED_USERNAME=
